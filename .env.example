# Copy to .env and fill in. Every EXPO_PUBLIC_* value is bundled into the client
# and is therefore PUBLIC by design — never put a server secret here.
# Server-only secrets (OPENAI_API_KEY, ACCOUNT_PURGE_SECRET, EXPO_ACCESS_TOKEN,
# REWARD_CODE_SECRET) live in Supabase function secrets, not in this file.

# --- Supabase (required) ---
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# --- Public web origin serving the web export (required before store submission) ---
# Privacy policy and terms are served from here; App Review fetches these URLs.
EXPO_PUBLIC_WEB_ORIGIN=https://macroleague.app
EXPO_PUBLIC_SUPPORT_EMAIL=nityanth.maramreddy@gmail.com

# --- Crash reporting (optional; no-op when unset) ---
# EXPO_PUBLIC_SENTRY_DSN=
# Set by CI for release tagging + sourcemap association.
# EXPO_PUBLIC_RELEASE=

# --- Product analytics (optional; each no-op when unset) ---
# EXPO_PUBLIC_AMPLITUDE_API_KEY=
# EXPO_PUBLIC_TELEMETRYDECK_APP_ID=
